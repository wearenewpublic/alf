# Server
PORT=1986
SERVICE_URL=http://localhost:1986

# ATProto network
PLC_ROOT=https://plc.directory
HANDLE_RESOLVER_URL=https://api.bsky.app

# Database (choose one)
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/alf.db
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/alf

# Encryption key (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Post-publish webhook (optional)
# Called with POST { uri, publishedAt } after each draft is successfully published
# POST_PUBLISH_WEBHOOK_URL=https://your-service.example.com/hooks/post-published

# Per-user draft limit (optional)
# Maximum number of active (draft/scheduled) posts per user. Unset = unlimited.
# MAX_DRAFTS_PER_USER=3

# Allowed ATProto collections (optional)
# Comma-separated NSIDs to restrict which record types ALF will accept. Defaults to * (all).
# OAuth scope becomes: repo:<value>?action=create
# Example: restrict to Bluesky posts only
# ALLOWED_COLLECTIONS=app.bsky.feed.post
