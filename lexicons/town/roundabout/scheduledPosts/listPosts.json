{
  "lexicon": 1,
  "id": "town.roundabout.scheduledPosts.listPosts",
  "defs": {
    "main": {
      "type": "query",
      "description": "List draft and scheduled posts for a user.",
      "parameters": {
        "type": "params",
        "required": ["repo"],
        "properties": {
          "repo": {
            "type": "string",
            "format": "at-identifier",
            "description": "The DID of the user whose drafts to list"
          },
          "status": {
            "type": "string",
            "description": "Filter by status (draft, scheduled, published, failed, cancelled)"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["posts"],
          "properties": {
            "posts": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "lex:town.roundabout.scheduledPosts.defs#draftView"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
